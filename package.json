{
  "name": "ltc-maintenance-program",
  "productName": "LTC Maintenance Program",
  "version": "1.0.0",
  "description": "LTC Maintenance Program desktop app",
  "author": "Your Name",
  "main": "main.js",

  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "release": "electron-builder --publish always"
  },

  "dependencies": {
    "electron-updater": "^6.8.3",
    "firebase": "^12.0.0"
  },

  "devDependencies": {
    "electron": "^37.0.0",
    "electron-builder": "^26.8.1"
  },

  "build": {
    "appId": "com.ltc.maintenance",
    "productName": "LTC Maintenance Program",

    "files": [
      "**/*",
      "!out/**",
      "!dist/**",
      "!node_modules/.cache/**"
    ],

    "directories": {
      "output": "dist"
    },

    "win": {
      "target": "nsis"
    },

    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },

    "publish": [
      {
        "provider": "github",
        "owner": "bjacoby24",
        "repo": "LTC"
      }
    ]
  }
}