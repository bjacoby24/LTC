{
  "name": "ltc-maintenance-program",
  "productName": "LTC Maintenance Program",
  "version": "1.0.7",
  "description": "LTC Maintenance Program desktop app",
  "author": "Brandon Jacoby",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win nsis",
    "dist": "electron-builder",
    "release": "electron-builder --publish always"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "firebase": "^12.0.0"
  },
  "devDependencies": {
    "electron": "^37.0.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.ltc.maintenance",
    "productName": "LTC Maintenance Program",
    "artifactName": "${productName}-Setup-${version}.${ext}",
    "files": [
      "index.html",
      "main.js",
      "preload.js",
      "firebase-config.js",
      "package.json",
      "images/**/*",
      "js/**/*",
      "styles.css",
      "workorder.html",
      "workorder.css",
      "workorder.js",
      "service-template.html",
      "service-template.css",
      "service-template.js"
    ],
    "directories": {
      "output": "dist"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "bjacoby24",
        "repo": "LTC"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "runAfterFinish": false,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "LTC Maintenance Program"
    }
  }
}